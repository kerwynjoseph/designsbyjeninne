# Resend (email notifications)
RESEND_API_KEY=

# Google Maps (address autocomplete on the booking flow)
# Enable "Maps JavaScript API" and "Places API" for this key in Google Cloud Console,
# and restrict it to this site's domain(s).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Travel fee rate, in TT$ charged per kilometer a booking location falls
# outside the Central Trinidad service area (see lib/data/location-config.ts).
# Optional - defaults to 7 if not set. Change this value in Vercel and
# redeploy to update the rate without touching any code.
NEXT_PUBLIC_TRAVEL_FEE_RATE_PER_KM=7
